{
  "name": "solidjs-starter",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@nvidia-elements/lint": "workspace:*",
    "eslint": "catalog:",
    "solid-devtools": "0.34.5",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "2.11.12"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "solid-js": "1.9.12"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../core:build"
      ]
    },
    "build": {
      "command": "vite build",
      "files": [
        "../../core/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json"
      ],
      "output": [
        ".next/**"
      ],
      "dependencies": [
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../lint:build"
      ]
    }
  }
}
