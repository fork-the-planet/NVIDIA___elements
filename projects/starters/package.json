{
  "name": "starters",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "build": "wireit"
  },
  "dependencies": {
    "@internals/tools": "workspace:*"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "node ./index.js",
      "files": [
        "../internals/tools/dist/**/project/**",
        "../internals/tools/dist/**/skills/**",
        "./angular/dist/**/*.js",
        "./bundles/dist/**/*.js",
        "./importmaps/dist/**/*.js",
        "./eleventy/dist/**/*.js",
        "./eleventy-ssr/dist/**/*.js",
        "./lit-library/dist/**/*.js",
        "./mcp-app/dist/**",
        "./mpa/dist/**/*.js",
        "./nextjs/dist/**/*.js",
        "./nuxt/dist/**/*.js",
        "./react/dist/**/*.js",
        "./solidjs/dist/**/*.js",
        "./svelte/dist/**/*.js",
        "./typescript/dist/**/*.js",
        "./vue/dist/**/*.js",
        "./index.js"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        {
          "script": "../internals/tools:build",
          "cascade": false
        },
        {
          "script": "./angular:build",
          "cascade": false
        },
        {
          "script": "./bundles:build",
          "cascade": false
        },
        {
          "script": "./importmaps:build",
          "cascade": false
        },
        {
          "script": "./eleventy:build",
          "cascade": false
        },
        {
          "script": "./eleventy-ssr:build",
          "cascade": false
        },
        {
          "script": "./hugo:build",
          "cascade": false
        },
        {
          "script": "./lit-library:build",
          "cascade": false
        },
        {
          "script": "./mcp-app:build",
          "cascade": false
        },
        {
          "script": "./mpa:build",
          "cascade": false
        },
        {
          "script": "./nextjs:build",
          "cascade": false
        },
        {
          "script": "./nuxt:build",
          "cascade": false
        },
        {
          "script": "./react:build",
          "cascade": false
        },
        {
          "script": "./solidjs:build",
          "cascade": false
        },
        {
          "script": "./svelte:build",
          "cascade": false
        },
        {
          "script": "./typescript:build",
          "cascade": false
        },
        {
          "script": "./vue:build",
          "cascade": false
        }
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true
        }
      }
    }
  }
}
