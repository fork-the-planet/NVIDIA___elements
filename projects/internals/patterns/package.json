{
  "name": "@internals/patterns",
  "version": "0.0.0",
  "private": true,
  "description": "HTML Patterns",
  "homepage": "https://NVIDIA.github.io/elements/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NVIDIA/elements.git"
  },
  "type": "module",
  "customElements": "dist/custom-elements.json",
  "contributes": {
    "html": {
      "customData": [
        "./dist/data.html.json"
      ]
    }
  },
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./custom-elements.json": "./dist/custom-elements.json",
    "./custom-elements-jsx": {
      "types": "./dist/custom-elements-jsx.d.ts"
    },
    "./*.examples.json": "./dist/*.examples.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "lit": "catalog:"
  },
  "peerDependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/themes": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/lint": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "eslint": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "dev": {
      "command": "vite",
      "dependencies": [
        "build:watch"
      ]
    },
    "ci": {
      "dependencies": [
        "build",
        "lint",
        "publint"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "vite build",
      "clean": "if-file-deleted",
      "files": [
        "../../core/dist/**/*.js",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../vite:ci",
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js",
        "!src/**/__screenshots__/**"
      ],
      "output": [],
      "dependencies": [
        "../eslint:ci",
        "../../lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../eslint:ci",
        "../../lint:build"
      ]
    }
  }
}
