{
  "name": "@internals/metadata",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node ./src/metadata.ts",
    "ci": "wireit",
    "build": "wireit",
    "generate:api": "wireit",
    "generate:tests": "wireit",
    "generate:examples": "wireit",
    "generate:adoption": "wireit",
    "generate:lighthouse": "wireit",
    "generate:wireit": "wireit",
    "generate:releases": "wireit",
    "generate:projects": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "test:coverage": "wireit",
    "lint": "wireit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./services/adoption.service.js": {
      "types": "./dist/services/adoption.service.d.ts",
      "default": "./dist/src/services/adoption.service.js"
    },
    "./services/api.service.js": {
      "types": "./dist/services/api.service.d.ts",
      "default": "./dist/src/services/api.service.js"
    },
    "./services/projects.service.js": {
      "types": "./dist/services/projects.service.d.ts",
      "default": "./dist/src/services/projects.service.js"
    },
    "./services/tests.service.js": {
      "types": "./dist/services/tests.service.d.ts",
      "default": "./dist/src/services/tests.service.js"
    }
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:coverage"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "NODE_ENV=production vite build",
      "files": [
        "src/**",
        "!src/**/*.test.ts",
        "static/adoption.json",
        "static/lighthouse.json",
        "static/releases.json",
        "static/tests.json",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../vite:ci",
        "generate:api",
        "generate:examples",
        "generate:projects",
        "generate:wireit"
      ]
    },
    "generate:api": {
      "command": "node ./src/tasks/api.ts",
      "files": [
        "./src/tasks/api.ts",
        "./src/tasks/api.utils.ts",
        "./src/utils/utils.ts",
        "../../code/package.json",
        "../../code/dist/custom-elements.json",
        "../../core/src/internal/types/index.ts",
        "../../core/package.json",
        "../../core/dist/custom-elements.json",
        "../../styles/package.json",
        "../../styles/dist/custom-elements.json",
        "../../themes/package.json",
        "../../themes/dist/custom-elements.json",
        "../../forms/package.json",
        "../../forms/dist/custom-elements.json",
        "../../markdown/package.json",
        "../../markdown/dist/custom-elements.json",
        "../../monaco/package.json",
        "../../monaco/dist/custom-elements.json",
        "../../patterns/package.json",
        "../../patterns/dist/custom-elements.json"
      ],
      "output": [
        "static/api.json"
      ],
      "dependencies": [
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../code:build",
          "cascade": false
        },
        {
          "script": "../../forms:build",
          "cascade": false
        },
        {
          "script": "../../markdown:build",
          "cascade": false
        },
        {
          "script": "../../monaco:build",
          "cascade": false
        }
      ]
    },
    "generate:projects": {
      "command": "node ./src/tasks/projects.ts",
      "files": [
        "./src/tasks/projects.ts",
        "./src/tasks/projects.utils.ts",
        "../../core/package.json",
        "../../core/README.md",
        "../../core/CHANGELOG.md",
        "../../styles/package.json",
        "../../styles/README.md",
        "../../styles/CHANGELOG.md",
        "../../themes/package.json",
        "../../themes/README.md",
        "../../themes/CHANGELOG.md",
        "../../code/package.json",
        "../../code/README.md",
        "../../code/CHANGELOG.md",
        "../../forms/package.json",
        "../../forms/README.md",
        "../../forms/CHANGELOG.md",
        "../../markdown/package.json",
        "../../markdown/README.md",
        "../../markdown/CHANGELOG.md",
        "../../monaco/package.json",
        "../../monaco/README.md",
        "../../monaco/CHANGELOG.md",
        "../../patterns/package.json",
        "../../patterns/README.md",
        "../../patterns/CHANGELOG.md"
      ],
      "output": [
        "static/projects.json"
      ]
    },
    "generate:tests": {
      "command": "node ./src/tasks/tests.ts",
      "files": [
        "./src/tasks/tests.ts",
        "./src/tasks/tests.utils.ts",
        "./static/lighthouse.json",
        "./coverage/unit/coverage-summary.json",
        "./coverage/unit/summary.json",
        "../../core/coverage/unit/coverage-summary.json",
        "../../core/coverage/unit/summary.json",
        "../../core/coverage/visual/summary.json",
        "../../core/coverage/ssr/summary.json",
        "../../styles/coverage/visual/summary.json",
        "../../themes/coverage/visual/summary.json",
        "../../cli/coverage/unit/coverage-summary.json",
        "../../cli/coverage/unit/summary.json",
        "../../lint/coverage/unit/coverage-summary.json",
        "../../lint/coverage/unit/summary.json",
        "../../code/coverage/unit/coverage-summary.json",
        "../../code/coverage/unit/summary.json",
        "../../code/coverage/visual/summary.json",
        "../../code/coverage/ssr/summary.json",
        "../../forms/coverage/unit/coverage-summary.json",
        "../../forms/coverage/unit/summary.json",
        "../../lint/coverage/unit/coverage-summary.json",
        "../../lint/coverage/unit/summary.json",
        "../../markdown/coverage/unit/coverage-summary.json",
        "../../markdown/coverage/unit/summary.json",
        "../../markdown/coverage/visual/summary.json",
        "../../markdown/coverage/ssr/summary.json",
        "../../monaco/coverage/unit/coverage-summary.json",
        "../../monaco/coverage/unit/summary.json",
        "../../monaco/coverage/visual/summary.json",
        "../../monaco/coverage/ssr/summary.json",
        "../tools/coverage/unit/coverage-summary.json",
        "../tools/coverage/unit/summary.json"
      ],
      "output": [
        "static/tests.json"
      ],
      "dependencies": [
        {
          "script": "test:coverage",
          "cascade": false
        },
        {
          "script": "../../core:test:coverage",
          "cascade": false
        },
        {
          "script": "../../core:test:ssr",
          "cascade": false
        },
        {
          "script": "../../core:test:visual",
          "cascade": false
        },
        {
          "script": "../../styles:test:visual",
          "cascade": false
        },
        {
          "script": "../../themes:test:visual",
          "cascade": false
        },
        {
          "script": "../../code:test:coverage",
          "cascade": false
        },
        {
          "script": "../../forms:test:coverage",
          "cascade": false
        },
        {
          "script": "../../markdown:test:coverage",
          "cascade": false
        },
        {
          "script": "../../monaco:test:coverage",
          "cascade": false
        },
        {
          "script": "../../cli:test:coverage",
          "cascade": false
        },
        {
          "script": "../../lint:test:coverage",
          "cascade": false
        },
        {
          "script": "../tools:test:coverage",
          "cascade": false
        }
      ]
    },
    "generate:examples": {
      "command": "node ./src/tasks/examples.ts",
      "clean": false,
      "files": [
        "./src/tasks/examples.ts",
        "./src/tasks/examples.utils.ts",
        "./src/utils/utils.ts",
        "../patterns/dist/**/*.examples.json",
        "../../core/dist/**/*.examples.json",
        "../../styles/dist/**/*.examples.json",
        "../../themes/dist/**/*.examples.json",
        "../../monaco/dist/**/*.examples.json",
        "../../code/dist/**/*.examples.json",
        "../../forms/dist/**/*.examples.json",
        "../../markdown/dist/**/*.examples.json"
      ],
      "output": [
        "static/examples.json"
      ],
      "dependencies": [
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../code:build",
          "cascade": false
        },
        {
          "script": "../../forms:build",
          "cascade": false
        },
        {
          "script": "../../monaco:build",
          "cascade": false
        },
        {
          "script": "../patterns:build",
          "cascade": false
        }
      ]
    },
    "generate:adoption": {
      "command": "node ./src/tasks/adoption.ts",
      "clean": false,
      "files": [
        "src/tasks/adoption.ts",
        "src/tasks/adoption.utils.ts",
        "../../*/package.json"
      ],
      "output": [
        "static/adoption.json"
      ]
    },
    "generate:lighthouse": {
      "command": "node ./src/tasks/lighthouse.ts",
      "clean": false,
      "files": [
        "src/tasks/lighthouse.ts",
        "src/tasks/lighthouse.utils.ts"
      ],
      "output": [
        "static/lighthouse.json"
      ],
      "dependencies": [
        "../../../:lighthouse"
      ]
    },
    "generate:wireit": {
      "command": "node ./src/tasks/wireit.ts",
      "clean": false,
      "files": [
        "src/tasks/wireit.ts",
        "src/tasks/wireit.utils.ts"
      ],
      "output": [
        "static/wireit.json"
      ],
      "dependencies": []
    },
    "generate:releases": {
      "command": "node ./src/tasks/releases.ts",
      "clean": false,
      "files": [
        "src/tasks/releases.ts",
        "src/tasks/releases.utils.ts"
      ],
      "output": [
        "static/releases.json"
      ],
      "dependencies": []
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../eslint:ci",
        "../../lint:build"
      ]
    },
    "test": {
      "command": "vitest run",
      "files": [
        "dist/**/*.js",
        "static/**/*.json",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "../vite:ci",
        "build"
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "dist/**/*.js",
        "static/**/*.json",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "../vite:ci",
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "dependencies": {
    "minisearch": "7.2.0"
  },
  "devDependencies": {
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "glob": "catalog:",
    "publint": "catalog:",
    "ts-morph": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
