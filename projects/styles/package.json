{
  "name": "@nvidia-elements/styles",
  "version": "0.0.8",
  "release": {
    "extends": "../../release.config.js"
  },
  "description": "Core CSS foundation for the Elements design system, providing layout utilities, typography styles, and view transitions.",
  "keywords": [
    "css",
    "layout",
    "typography"
  ],
  "homepage": "https://NVIDIA.github.io/elements/",
  "customElements": "dist/custom-elements.json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NVIDIA/elements.git",
    "directory": "projects/styles"
  },
  "sideEffects": [
    "./dist/**/*.css"
  ],
  "type": "module",
  "contributes": {
    "html": {
      "customData": [
        "./dist/data.html.json"
      ]
    }
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "NOTICE.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./CHANGELOG.md": "./CHANGELOG.md",
    "./data.html.json": "./dist/data.html.json",
    "./*.examples.json": "./dist/*.examples.json",
    "./layout.css": "./dist/layout.css",
    "./labs/layout-viewport.css": "./dist/labs/layout-viewport.css",
    "./labs/layout-container.css": "./dist/labs/layout-container.css",
    "./typography.css": "./dist/typography.css",
    "./view-transitions.css": "./dist/view-transitions.css",
    "./bundles/*": "./dist/bundles/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "test:lighthouse": "wireit",
    "test:visual": "wireit"
  },
  "peerDependencies": {
    "@nvidia-elements/themes": "workspace:>=0.0.0 <1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@internals/testing": "workspace:*",
    "@internals/vite": "workspace:*",
    "@nvidia-elements/lint": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@vitest/browser": "catalog:",
    "cssnano": "8.0.0",
    "eslint": "catalog:",
    "lit": "catalog:",
    "postcss": "catalog:",
    "postcss-each": "1.1.0",
    "postcss-load-config": "6.0.1",
    "postcss-mixins": "12.1.2",
    "publint": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:visual"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "dev": {
      "dependencies": [
        "build:watch"
      ]
    },
    "build": {
      "command": "NODE_ENV=production vite build && node ./build/metadata.js",
      "files": [
        "src/**",
        "!src/**/*.test.lighthouse.ts",
        "!src/**/*.test.visual.ts",
        "package.json",
        "vite.config.ts",
        "postcss.config.cjs",
        "build/metadata.js"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../themes:build",
        "../internals/vite:ci"
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": []
    },
    "test:lighthouse": {
      "command": "playwright-lock 'vitest run --config=vitest.lighthouse.ts'",
      "files": [
        "src/index.test.lighthouse.ts",
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.html",
        "vitest.lighthouse.ts"
      ],
      "output": [
        ".lighthouse"
      ],
      "dependencies": [
        "build",
        "../internals/vite:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:visual": {
      "command": "vitest run --config=vitest.visual.ts",
      "clean": false,
      "files": [
        "dist/**/*.css",
        "src/index.test.visual.ts",
        "src/**/*.test.visual.ts",
        "vitest.visual.html",
        "vitest.visual.ts"
      ],
      "output": [
        ".visual/*.png"
      ],
      "dependencies": [
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ]
    },
    "lint": {
      "dependencies": [
        "lint:eslint"
      ]
    },
    "lint:eslint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js",
        "!src/**/__screenshots__/**"
      ],
      "output": [],
      "dependencies": [
        "../lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../lint:build"
      ]
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "license": "Apache-2.0"
}
