{
  "name": "site",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "dev:fast": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "test": "wireit",
    "test:lighthouse": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "test"
      ]
    },
    "dev": {
      "command": "pnpm exec eleventy --incremental --serve --quiet --port=8082",
      "service": true,
      "dependencies": [
        "build:dependencies"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "dev:fast": {
      "command": "pnpm exec eleventy --incremental --serve --quiet --port=8082",
      "service": true,
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "rm -rf dist .11ty-vite && pnpm exec eleventy",
      "files": [
        "src",
        "!src/**/*.test.js",
        "!src/**/*.test.lighthouse.ts",
        "public",
        "!public/llms.txt",
        "./eleventy.config.js"
      ],
      "dependencies": [
        "build:dependencies"
      ],
      "output": [
        "dist/**"
      ],
      "env": {
        "NODE_ENV": "production",
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        },
        "ELEMENTS_SITE_URL": {
          "external": true,
          "default": "https://nvidia.github.io"
        },
        "LOCAL_PREVIEW": {
          "external": true,
          "default": "false"
        }
      }
    },
    "build:dependencies": {
      "command": "echo 'building dependencies...'",
      "files": [
        "../core/dist/**/*.js",
        "../core/dist/**/*.examples.json",
        "../styles/dist/**/*.css",
        "../styles/dist/**/*.examples.json",
        "../themes/dist/**/*.css",
        "../themes/dist/**/*.examples.json",
        "../themes/dist/**/*.json",
        "../code/dist/**/*.js",
        "../code/dist/**/*.examples.json",
        "../forms/dist/**/*.js",
        "../forms/dist/**/*.examples.json",
        "../markdown/dist/**/*.js",
        "../markdown/dist/**/*.examples.json",
        "../media/dist/**/*.js",
        "../media/dist/**/*.examples.json",
        "../monaco/dist/**/*.js",
        "../monaco/dist/**/*.examples.json",
        "../internals/metadata/static/**",
        "../internals/patterns/dist/**/*.js",
        "../internals/patterns/dist/**/*.examples.json",
        "../internals/tools/dist/**/*.js",
        "../internals/tools/dist/**/*.examples.json"
      ],
      "dependencies": [
        {
          "script": "../core:build",
          "cascade": false
        },
        {
          "script": "../styles:build",
          "cascade": false
        },
        {
          "script": "../themes:build",
          "cascade": false
        },
        {
          "script": "../code:build",
          "cascade": false
        },
        {
          "script": "../forms:build",
          "cascade": false
        },
        {
          "script": "../markdown:build",
          "cascade": false
        },
        {
          "script": "../media:build",
          "cascade": false
        },
        {
          "script": "../monaco:build",
          "cascade": false
        },
        {
          "script": "../internals/metadata:build",
          "cascade": false
        },
        {
          "script": "../internals/patterns:build",
          "cascade": false
        },
        {
          "script": "../internals/tools:build",
          "cascade": false
        }
      ],
      "output": []
    },
    "preview": {
      "command": "pnpm run build && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "files": [
        "src",
        "public",
        "./eleventy.config.js"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/"
        }
      }
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:style"
      ]
    },
    "lint:eslint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.js",
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci",
        "../lint:build"
      ]
    },
    "lint:style": {
      "command": "stylelint 'src/**/*.css' --config=../../stylelint.config.mjs",
      "files": [
        "src/**/*.css",
        "../../stylelint.config.mjs"
      ],
      "output": []
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../internals/eslint:ci",
        "../lint:build"
      ]
    },
    "test": {
      "command": "vitest run src/_11ty/layouts/metadata.test.ts src/_11ty/layouts/links.test.ts src/_11ty/transforms/site-urls.test.ts src/_11ty/shortcodes/api.test.ts src/_11ty/shortcodes/example.test.ts src/_11ty/plugins/llms-txt.test.ts src/_11ty/plugins/sitemap-xml.test.ts src/_11ty/utils/env.test.ts src/docs/metrics/api-status.test.ts src/examples/index.test.ts",
      "files": [
        "src/**/*.js",
        "src/**/*.md",
        "src/**/*.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "build"
      ]
    },
    "test:lighthouse": {
      "command": "playwright-lock 'vitest run --config=vitest.lighthouse.ts'",
      "files": [
        "src/index.test.lighthouse.ts",
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.ts"
      ],
      "output": [
        "coverage/lighthouse/junit.xml"
      ],
      "dependencies": [
        "build",
        "../internals/vite:ci"
      ],
      "env": {
        "NODE_ENV": "production",
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    }
  },
  "dependencies": {
    "3d-force-graph": "1.79.0",
    "chart.js": "4.5.1",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@11ty/eleventy": "catalog:",
    "@11ty/eleventy-plugin-vite": "catalog:",
    "@eslint/js": "catalog:",
    "@internals/eslint": "workspace:*",
    "@internals/metadata": "workspace:*",
    "@internals/patterns": "workspace:*",
    "@internals/tools": "workspace:*",
    "@internals/vite": "workspace:*",
    "@lit-labs/eleventy-plugin-lit": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/forms": "workspace:*",
    "@nvidia-elements/lint": "workspace:*",
    "@nvidia-elements/markdown": "workspace:*",
    "@nvidia-elements/media": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "compare-versions": "6.1.1",
    "eslint": "catalog:",
    "html-minifier-next": "5.2.2",
    "lighthouse": "catalog:",
    "lightningcss": "1.30.2",
    "markdown-it": "catalog:",
    "markdown-it-link-attributes": "catalog:",
    "pagefind": "1.3.0",
    "parse5": "7.1.2",
    "playwright": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
